# RAG Pipeline Configuration
# Copy this file to .env and fill in your values

# ====================
# Core Settings
# ====================
DATA_DIR=data
VECTOR_DB_DIR=vector_db
KG_JSON_PATH=kg_store.json
MANIFEST_PATH=.file_manifest.json
LOG_LEVEL=INFO

# ====================
# Embeddings & LLM
# ====================
# Ollama models (running on localhost:11434)
EMBEDDING_MODEL=nomic-embed-text:latest
LLM_MODEL=qwen:latest

# ====================
# Chunking
# ====================
CHUNK_SIZE=1000
CHUNK_OVERLAP=200
TEXT_SPLITTER_MODE=recursive

# ====================
# Retrieval
# ====================
TOP_K=20
FINAL_K=5
BM25_WEIGHT=0.5
VECTOR_WEIGHT=0.5

# ====================
# Reranker (Cross-Encoder)
# ====================
# Model from HuggingFace Hub
RERANKER_MODEL=BAAI/bge-reranker-v2-m3
RERANKER_TOP_K=5
RERANKER_THRESHOLD=0.1

# ====================
# Fact Verification
# ====================
ENABLE_FACT_VERIFICATION=true
FACT_VERIFICATION_THRESHOLD=0.6

# ====================
# LangSmith Observability & Tracing
# ====================
# Get your API key from: https://smith.langchain.com/
# 1. Sign up at https://smith.langchain.com/
# 2. Create a new project
# 3. Copy your API key from Settings
ENABLE_LANGSMITH=true
LANGSMITH_API_KEY=your_api_key_here
LANGSMITH_PROJECT=rag-chatbot

# ====================
# Neo4j (Optional, currently using NetworkX)
# ====================
NEO4J_URI=bolt://localhost:7687
NEO4J_USER=neo4j
NEO4J_PASSWORD=password
